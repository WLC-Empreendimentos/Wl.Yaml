# ============================================================================
# vscode-yaml - .gitignore
# ============================================================================

# ----- Node / TypeScript -----------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-store/

# ----- Build -----------------------------------------------------------------
dist/
out/
*.js.map

# ----- Cobertura de testes ---------------------------------------------------
coverage/
*.lcov
.nyc_output/

# ----- VS Code Extension -----------------------------------------------------
*.vsix

# ----- VS Code (editor) ------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# ----- Sistema operacional ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
*.bak
*.orig

# ----- Logs e dumps ----------------------------------------------------------
*.log
logs/

# ----- Segredos e ambiente ---------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template

# ----- Editores --------------------------------------------------------------
*.code-workspace
.idea/

# ----- Working files locais (NAO versionar) ----------------------------------
*.scratch
DRAFT_*
RASCUNHO_*

# Logs do GitHub Actions baixados via `gh run download` (apenas para debug local)
.actions/

# ----- Cache de hooks / ferramentas ------------------------------------------
.cache/
_old/
