# ============================================================================
# vscode-yaml - EditorConfig
# ============================================================================
# Padronizacao de formatacao para todos os editores que suportam EditorConfig.
# Referencia: docs/padronizacao/qualidade/CICD.md
# ============================================================================

root = true

# ----------------------------------------------------------------------------
# Defaults para todos os arquivos
# ----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# ----------------------------------------------------------------------------
# TypeScript / JavaScript
# ----------------------------------------------------------------------------
[*.{ts,tsx,js,mjs,cjs}]
indent_size = 4
max_line_length = 120

# ----------------------------------------------------------------------------
# Configuracoes de projeto e tooling
# ----------------------------------------------------------------------------
# package.json, tsconfig, jest, webpack, eslint — padrao npm/ecossistema Node
[{package.json,package-lock.json,tsconfig*.json,jest.config.*,webpack.config.*,.eslintrc*,.eslintignore,.prettierrc*}]
indent_size = 2

# ----------------------------------------------------------------------------
# YAML / TOML
# ----------------------------------------------------------------------------
[*.{yml,yaml,toml}]
indent_size = 2

# ----------------------------------------------------------------------------
# JSON (geral)
# ----------------------------------------------------------------------------
# package.json e tsconfig tem regra propria acima com prioridade maior.
[*.json]
indent_size = 2

# ----------------------------------------------------------------------------
# Markdown
# ----------------------------------------------------------------------------
# Markdown legitimamente usa 3 espacos para continuar listas (apos "- ").
# trim_trailing_whitespace = false para preservar line breaks intencionais (dois espacos).
# Validacao de estilo delegada ao markdownlint-cli2.
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# ----------------------------------------------------------------------------
# Shell scripts
# ----------------------------------------------------------------------------
[*.{sh,bash}]
indent_size = 4
end_of_line = lf

# ----------------------------------------------------------------------------
# Arquivos de extensao VS Code
# ----------------------------------------------------------------------------
[*.vscodeignore]
indent_size = 2

# launch.json e settings.json do workspace
[.vscode/*.json]
indent_size = 2

# ----------------------------------------------------------------------------
# GitHub Actions
# ----------------------------------------------------------------------------
[.github/**/*.{yml,yaml}]
indent_size = 2

# ----------------------------------------------------------------------------
# Arquivos binarios — sem normalizacao de linha nem trailing whitespace
# ----------------------------------------------------------------------------
[*.{vsix,png,jpg,jpeg,gif,ico,svg,woff,woff2,ttf,eot}]
insert_final_newline = false
trim_trailing_whitespace = false

# ----------------------------------------------------------------------------
# Makefiles (sempre tab)
# ----------------------------------------------------------------------------
[Makefile]
indent_style = tab
